  "confidence_rules": {
    "_comment_v2": "Thêm v2.0 — gắn fact_type và fetch_strategy cho từng nguồn để ngăn hallucination",
    "_version": "2.0",

    "fact_type_mapping": {
      "tier1_vn_market":      "B_FINANCIAL",
      "tier1_policy_law":    "C_REGULATORY",
      "tier2_global_macro":  "A_GEOPOLITICAL",
      "tier3_tech_ai":       "E_TECH_AI",
      "tier4_substack_experts": "D_EXPERT_OPINION",
      "tier5_x_twitter":     "F_MARKET_COLOR",
      "tier6_brave_search":  "A_GEOPOLITICAL"
    },

    "fetch_strategy_by_type": {
      "A_GEOPOLITICAL": {
        "required": "article_body",
        "fallback": "topic_hint_only",
        "note": "Không viết FACT geopolitical khi chỉ có RSS headline"
      },
      "B_FINANCIAL": {
        "required": "≥2 independent sources",
        "fallback": "single_source_with_UNVERIFIED_flag",
        "note": "Số liệu thị trường cần cross-reference"
      },
      "C_REGULATORY": {
        "required": "official_source_or_summary",
        "fallback": "verify_when_possible",
        "note": "Luật/thuế: ưu tiên nguồn official"
      },
      "D_EXPERT_OPINION": {
        "required": "article_body_from_source",
        "fallback": "summary_with_attribution",
        "note": "Substack/blog: ưu tiên article gốc"
      },
      "E_TECH_AI": {
        "required": "headline_and_snippet",
        "fallback": "headline_only",
        "note": "RSS acceptable cho tin tech/AI"
      },
      "F_MARKET_COLOR": {
        "required": "≥1 source",
        "fallback": "use_with_caution",
        "note": "Market color: ≥1 nguồn là đủ, nhưng flag nếu đơn lẻ"
      }
    },

    "high_risk_patterns": {
      "_comment": "Các pattern trong raw headline → trigger flag trước khi viết FACT",
      "patterns": [
        {
          "pattern": "actor_unclear",
          "regex": "(tấn công|bắn|nổ|phóng|khai hỏa|bắt đầu|kết thúc|lệnh ngừng bắn).*(ai|ai là|ai đã|nước nào|phía nào)",
          "action": "VERIFY_ACTOR",
          "note": "Headline có action nhưng không rõ ai làm → bắt buộc đọc article"
        },
        {
          "pattern": "specific_numbers",
          "regex": "\\d{2,}[\\s\\w]*(người|triệu|tỷ|nghìn|vụ|chiến|cuộc|máy bay|tên lửa|UAV|drone|dầu|lãi suất|điểm|%)",
          "action": "VERIFY_NUMBER",
          "note": "Số cụ thể cần verify từ article gốc"
        },
        {
          "pattern": "geopolitical_country",
          "regex": "(Iran|Nga|Mỹ|Trung Quốc|Ukraine|North Korea|Taiwan|Houthi|Hezbollah).*(tấn công|đáp trả|le|oscalation|deescalation)",
          "action": "VERIFY_COUNTRY_CONTEXT",
          "note": "Tin geopolitical luôn verify actor và context trước khi viết"
        }
      ]
    },

    "article_body_targets": {
